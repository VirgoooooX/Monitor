{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "lib": ["ES2022"],
    "types": ["node"],
    "outDir": "dist",
    "rootDir": "src",
    "sourceMap": true,
    "declaration": false
  },
  "include": ["src/main/**/*.ts", "src/preload/**/*.ts"],
  "exclude": ["src/renderer/**", "**/*.test.ts", "**/*.spec.ts", "node_modules"]
}
