{
  "name": "desktop-monitor-widget",
  "version": "0.1.0",
  "private": true,
  "description": "Windows desktop floating widget that monitors OpenClash node connectivity and AI usage.",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "typecheck": "tsc -p tsconfig.main.json --noEmit && tsc -p tsconfig.renderer.json --noEmit",
    "clean": "node scripts/clean.mjs",
    "build": "npm run clean && tsc -p tsconfig.main.json && vite build",
    "test": "vitest run",
    "package": "npm run build && electron-builder --win"
  },
  "dependencies": {
    "better-sqlite3": "11.5.0",
    "lucide-react": "0.460.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "7.6.12",
    "@types/node": "22.10.1",
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1",
    "@vitejs/plugin-react": "4.3.4",
    "electron": "33.2.1",
    "electron-builder": "25.1.8",
    "fast-check": "3.23.1",
    "typescript": "5.6.3",
    "vite": "5.4.11",
    "vitest": "2.1.8"
  }
}
