{
  "name": "desktop-monitor-widget",
  "version": "0.2.1",
  "private": true,
  "description": "Windows desktop floating widget that monitors OpenClash node connectivity and AI usage.",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "i18n:validate": "node scripts/validate-i18n-catalogs.mjs",
    "i18n:validate:bundle": "node scripts/validate-i18n-catalogs.mjs --check-bundle",
    "typecheck": "npm run i18n:validate && tsc -p tsconfig.main.json --noEmit && tsc -p tsconfig.renderer.json --noEmit",
    "clean": "node scripts/clean.mjs",
    "build": "npm run clean && npm run i18n:validate && tsc -p tsconfig.main.json && node scripts/bundle-preload.mjs && vite build && npm run i18n:validate:bundle",
    "test": "vitest run",
    "package": "npm run build && electron-builder --win --publish never",
    "prepackage:mac": "node scripts/prepackage-mac.mjs",
    "package:mac": "npm run prepackage:mac && npm run build && electron-builder --mac --x64 --arm64 --publish never",
    "icons": "node scripts/gen-icons.mjs"
  },
  "dependencies": {
    "@lobehub/icons-static-svg": "1.90.0",
    "better-sqlite3": "11.5.0",
    "lucide-react": "0.460.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/better-sqlite3": "7.6.12",
    "@types/node": "22.10.1",
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1",
    "@vitejs/plugin-react": "4.3.4",
    "electron": "33.2.1",
    "electron-builder": "25.1.8",
    "esbuild": "^0.28.0",
    "fast-check": "3.23.1",
    "jsdom": "^29.1.1",
    "tsx": "^4.22.4",
    "typescript": "5.6.3",
    "vite": "5.4.11",
    "vitest": "2.1.8"
  }
}
